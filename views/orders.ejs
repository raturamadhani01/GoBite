<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
  <% const pageMessage=typeof message !=="undefined" ? message : null; %>
    <% const pageError=typeof error !=="undefined" ? error : null; %>
      <% const toRupiah=typeof formatRupiah !=="undefined" ? formatRupiah : (value)=> new Intl.NumberFormat("id-ID", {
        style: "currency", currency: "IDR", maximumFractionDigits: 0 }).format(Number(value) || 0); %>
        <%- include("navbar", { search: "" }) %>

          <div class="container py-4">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h3 class="mb-0">Orders</h3>
              <% if (userRole==="pembeli" ) { %>
                <a href="/orders/add" class="btn btn-dark">+ Add Order</a>
                <% } %>
            </div>

            <!-- Alerts -->
            <% if (pageMessage) { %>
              <div class="alert alert-success alert-dismissible fade show" role="alert">
                Pesanan berhasil dihapus
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
              <% } %>
                <% if (pageError) { %>
                  <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= pageError %>
                      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                  </div>
                  <% } %>

                    <!-- Filter Card -->
                    <div class="card shadow-sm mb-4">
                      <div class="card-header bg-dark text-white fw-semibold">
                        🔍 Filter Orders
                      </div>
                      <div class="card-body">
                        <form method="get" action="/orders" class="row g-3 align-items-end">
                          <!-- Driver filter -->
                          <div class="col-md-5">
                            <label class="form-label fw-semibold">Driver</label>
                            <select name="driverId" class="form-select">
                              <option value="">-- All Drivers --</option>
                              <% drivers.forEach(driver=> { %>
                                <option value="<%= driver.id %>" <%=filterDriverId==driver.id ? "selected" : "" %>>
                                  <%= driver.name %> (<%= driver.privatePhone %>)
                                </option>
                                <% }) %>
                            </select>
                          </div>

                          <!-- Food / Menu filter -->
                          <div class="col-md-5">
                            <label class="form-label fw-semibold">Food (Menu)</label>
                            <select name="menuId" class="form-select">
                              <option value="">-- All Food Items --</option>
                              <% menus.forEach(menu=> { %>
                                <option value="<%= menu.id %>" <%=filterMenuId==menu.id ? "selected" : "" %>>
                                  <%= menu.menu %>
                                </option>
                                <% }) %>
                            </select>
                          </div>

                          <!-- Buttons -->
                          <div class="col-md-2 d-flex gap-2">
                            <button type="submit" class="btn btn-dark flex-fill">Apply</button>
                            <a href="/orders" class="btn btn-outline-secondary flex-fill">Reset</a>
                          </div>
                        </form>
                      </div>
                    </div>

                    <!-- Active filter badge -->
                    <% if (filterDriverId || filterMenuId) { %>
                      <div class="mb-3 d-flex gap-2 flex-wrap">
                        <% if (filterDriverId) { const d=drivers.find(x=> String(x.id) === String(filterDriverId));
                          %>
                          <span class="badge bg-dark fs-6 py-2 px-3">
                            🚗 Driver: <%= d ? d.name : filterDriverId %>
                              <a href="/orders?menuId=<%= filterMenuId %>"
                                class="text-white ms-2 text-decoration-none">✕</a>
                          </span>
                          <% } %>
                            <% if (filterMenuId) { const m=menus.find(x=> String(x.id) === String(filterMenuId));
                              %>
                              <span class="badge bg-success fs-6 py-2 px-3">
                                🍔 Food: <%= m ? m.menu : filterMenuId %>
                                  <a href="/orders?driverId=<%= filterDriverId %>"
                                    class="text-white ms-2 text-decoration-none">✕</a>
                              </span>
                              <% } %>
                                <span class="badge bg-secondary fs-6 py-2 px-3">
                                  <%= data.length %> result<%= data.length !==1 ? "s" : "" %>
                                </span>
                      </div>
                      <% } %>

                        <!-- Joint Results Table -->
                        <div class="table-responsive">
                          <table class="table table-bordered table-hover bg-white shadow-sm">
                            <thead class="table-dark">
                              <tr>
                                <th>#</th>
                                <th>Order Name</th>
                                <th>Address</th>
                                <th>Customer</th>
                                <th>🚗 Driver</th>
                                <th>Phone</th>
                                <th>🍔 Ordered Food</th>
                                <th>Total Price</th>
                                <th>Action</th>
                              </tr>
                            </thead>
                            <tbody>
                              <% if (data.length===0) { %>
                                <tr>
                                  <td colspan="9" class="text-center text-muted py-4">
                                    No orders found for the selected filter.
                                  </td>
                                </tr>
                                <% } else { %>
                                  <% data.forEach((order, index)=> { %>
                                    <tr>
                                      <td>
                                        <%= index + 1 %>
                                      </td>
                                      <td><strong>
                                          <%= order.name %>
                                        </strong></td>
                                      <td><span class="text-muted small">
                                          <%= order.address %>
                                        </span></td>
                                      <td>
                                        <% if (order.User) { %>
                                          <span class="badge bg-secondary">
                                            <%= order.User.name %>
                                          </span>
                                          <% } else { %> – <% } %>
                                      </td>

                                      <!-- Driver column (highlighted if filtered) -->
                                      <td class="<%= filterDriverId ? 'table-warning' : '' %>">
                                        <% if (order.Driver) { %>
                                          <strong>
                                            <%= order.Driver.name %>
                                          </strong><br>
                                          <span class="badge bg-dark">
                                            <%= order.Driver.license %>
                                          </span>
                                          <% } else { %> – <% } %>
                                      </td>
                                      <td>
                                        <% if (order.Driver) { %>
                                          <span class="small">
                                            <%= order.Driver.phoneNumber %>
                                          </span>
                                          <% } else { %> – <% } %>
                                      </td>

                                      <!-- Food column (highlighted if filtered) -->
                                      <td class="<%= filterMenuId ? 'table-success' : '' %>">
                                        <% if (order.Menus && order.Menus.length) { %>
                                          <% order.Menus.forEach(menu=> { %>
                                            <span class="badge bg-light text-dark border mb-1 d-inline-block">
                                              🍔 <%= menu.menu %>
                                            </span>
                                            <% }) %>
                                              <% } else { %> – <% } %>
                                      </td>

                                      <!-- Price -->
                                      <td>
                                        <% const fallback=(order.Menus || []).reduce((s, m)=> s + Number(m.price || 0),
                                          0); %>
                                          <% const finalPrice=order.price || fallback; %>
                                            <span class="fw-semibold text-success">
                                              <%= toRupiah(finalPrice) %>
                                            </span>
                                      </td>

                                      <!-- Action -->
                                      <td>
                                        <a href="/orders/<%= order.id %>/invoice"
                                          class="btn btn-sm btn-outline-dark mb-1" title="Download Invoice PDF">🧾
                                          Invoice</a>
                                        <% if (userRole==="penjual" ) { %>
                                          <a href="/orders/<%= order.id %>/delete" class="btn btn-sm btn-danger mb-1"
                                            onclick="return confirm('Yakin ingin menghapus pesanan ini?')">Delete</a>
                                          <% } %>
                                      </td>
                                    </tr>
                                    <% }) %>
                                      <% } %>
                            </tbody>
                          </table>
                        </div>

          </div>

          <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>