<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Order</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <% const formInput = typeof oldInput !== "undefined" ? oldInput : { name: "", address: "", DriverId: "", price: "" }; %>
  <%- include("navbar", { search: "" }) %>
  <div class="container py-4">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card shadow-sm">
          <div class="card-body">
            <h3 class="mb-3">Add Order</h3>
            <% if (errors.length) { %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% errors.forEach(error => { %>
                    <li><%= error %></li>
                  <% }) %>
                </ul>
              </div>
            <% } %>
            <form action="/orders/add" method="post" id="order-form">
              <% const selectedIds = typeof preselectedMenuIds !== "undefined" ? preselectedMenuIds : []; %>
              <div class="mb-3">
                <label class="form-label">Order Name</label>
                <input type="text" name="name" class="form-control" value="<%= formInput.name %>" >
              </div>
              <div class="mb-3">
                <label class="form-label">Address</label>
                <input
                  type="text"
                  name="address"
                  class="form-control"
                  value="<%= formInput.address %>"
                  
                  minlength="15"
                  maxlength="255"
                >
              </div>
              <div class="mb-3">
                <label class="form-label">Driver</label>
                <select name="DriverId" class="form-select" >
                  <option value="">-- Pilih Driver --</option>
                  <% drivers.forEach(driver => { %>
                    <option value="<%= driver.id %>" <%= String(formInput.DriverId) === String(driver.id) ? "selected" : "" %>><%= driver.name %> - <%= driver.privatePhone %></option>
                  <% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Menus</label>
                <% menus.forEach(menu => { %>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      name="menuIds"
                      value="<%= menu.id %>"
                      id="menu-<%= menu.id %>"
                      <%= selectedIds.includes(String(menu.id)) ? "checked" : "" %>
                    >
                    <label class="form-check-label" for="menu-<%= menu.id %>">
                      <%= menu.menu %> (Rp <%= menu.price %>)
                    </label>
                  </div>
                <% }) %>
              </div>
              <button class="btn btn-dark w-100">Save Order</button>
            </form>
            <script>
              (function () {
                const form = document.getElementById("order-form");
                if (!form) return;
                form.addEventListener("submit", function (event) {
                  const checkedMenus = form.querySelectorAll('input[name="menuIds"]:checked');
                  if (checkedMenus.length === 0) {
                    event.preventDefault();
                    alert("Pilih minimal 1 menu terlebih dahulu.");
                  }
                });
              })();
            </script>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
