<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>GoBite</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #f8f9fa;
    }

    .navbar-brand {
      font-weight: bold;
      font-size: 1.5rem;
    }

    .hero-section {
      background: linear-gradient(135deg, #ff4d4d, #ff1a1a);
      color: white;
      padding: 60px 0;
    }

    .card:hover {
      transform: translateY(-5px);
      transition: 0.3s ease;
    }

    .promo-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      background: red;
      color: white;
      padding: 5px 10px;
      font-size: 12px;
      border-radius: 20px;
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
    <%- include("navbar") %>

<!-- SLIDE PROMOSI -->
<div id="promoCarousel" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="https://images.unsplash.com/photo-1600891964599-f61ba0e24092"
           class="d-block w-100"
           style="height:400px; object-fit:cover;">
      <div class="carousel-caption d-none d-md-block">
        <h3>🔥 Diskon 50% Hari Ini!</h3>
        <p>Promo terbatas hanya untuk pelanggan baru</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="https://images.unsplash.com/photo-1550547660-d9450f859349"
           class="d-block w-100"
           style="height:400px; object-fit:cover;">
      <div class="carousel-caption d-none d-md-block">
        <h3>🚚 Gratis Ongkir</h3>
        <p>Untuk 100 order pertama hari ini</p>
      </div>
    </div>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#promoCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#promoCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>

<!-- HERO SECTION -->
<section class="hero-section text-center">
  <div class="container">
    <h1 class="fw-bold">Pesan Makanan Lebih Cepat</h1>
    <p class="lead">Sistem driver otomatis siap mengantar makanan favoritmu</p>
    <a href="/login" class="btn btn-light btn-lg mt-3">Mulai Sekarang</a>
  </div>
</section>

<!-- MENU TERBARU -->
<section class="container py-5">
  <h2 class="text-center fw-bold mb-4">Menu Terbaru</h2>

  <div class="row">
    <% if (data.length === 0) { %>
      <div class="text-center">
        <p>Belum ada menu tersedia</p>
      </div>
    <% } %>

    <% data.forEach(menu => { %>
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 position-relative">
          
          <span class="promo-badge">Promo</span>

         <img src="<%= menu.imageUrl %>" class="card-img-top" style="height:200px; object-fit:cover;">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= menu.menu %></h5>
            <p class="card-text text-muted">Rp <%= menu.price %></p>

            <a href="/login" class="btn btn-danger mt-auto w-100">
              Order Sekarang
            </a>
          </div>
        </div>
      </div>
    <% }) %>

  </div>
</section>

<!-- FOOTER -->
<footer class="bg-dark text-white text-center py-3">
  <p class="mb-0">© 2026 GoBite - Food Delivery App</p>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>