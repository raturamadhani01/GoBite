<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
  <%- include("navbar", { search }) %>
    <div class="container py-4">

      <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
          <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="mb-0">Menu List</h3>
            <div class="d-flex gap-2">
              <form method="get" action="/menus" class="d-flex gap-2">
                <input type="hidden" name="search" value="<%= search || '' %>">
                <select name="sort" class="form-select">
                  <option value="">Sort by</option>
                  <option value="price_asc" <%=sort==="price_asc" ? "selected" : "" %>>Price Asc</option>
                  <option value="price_desc" <%=sort==="price_desc" ? "selected" : "" %>>Price Desc</option>
                </select>
                <button class="btn btn-outline-secondary">Apply</button>
              </form>
              <% if (userRole==="penjual" ) { %>
                <a href="/menus/add" class="btn btn-dark">Add Menu</a>
                <% } %>
            </div>
          </div>


          <div class="row">
            <% data.forEach(menu=> { %>
              <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                  <img src="<%= menu.imageUrl %>" class="card-img-top" style="height: 180px; object-fit: cover;"
                    alt="<%= menu.menu %>">
                  <div class="card-body">
                    <h5 class="card-title">
                      <%= menu.menu %>
                    </h5>
                    <p class="mb-1 fw-semibold text-success">
                      <%= menu.priceToRupiah %>
                    </p>
                    <p class="small text-muted">
                      <%= menu.description %>
                    </p>
                  </div>
                  <div class="card-footer">
                    <% if (userRole === "penjual") { %>
                      <div class="d-flex gap-2 mb-2">
                        <a href="/menus/<%= menu.id %>/edit" class="btn btn-outline-primary w-100">Edit</a>
                        <a href="/menus/<%= menu.id %>/delete" class="btn btn-outline-danger w-100"
                          onclick="return confirm('Yakin ingin hapus menu ini?')">Delete</a>
                      </div>
                    <% } %>
                    <% if (userRole !== "penjual") { %>
                      <a href="/orders/add?menuId=<%= menu.id %>" class="btn btn-dark w-100">Order</a>
                    <% } %>
                  </div>
                </div>
              </div>
              <% }) %>
          </div>
    </div>

    <div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header bg-dark text-white">
            <h5 class="modal-title" id="orderModalLabel">🛒 Order: <span id="modal-menu-name"></span></h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <form action="/orders/add" method="post" id="quick-order-form">
            <div class="modal-body">
              <input type="hidden" name="menuIds" id="modal-menu-id">

              <div class="mb-3">
                <label class="form-label fw-semibold">Order Name</label>
                <input type="text" name="name" class="form-control" placeholder="e.g. Lunch order" >
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">Delivery Address</label>
                <input type="text" name="address" class="form-control" placeholder="Min. 15 characters" minlength="15"
                  maxlength="255" >
              </div>


              <div class="mb-3">
                <label class="form-label fw-semibold">🚗 Choose Driver</label>
                <select name="DriverId" class="form-select" >
                  <option value="">-- Select a Driver --</option>
                  <% drivers.forEach(driver=> { %>
                    <option value="<%= driver.id %>">
                      <%= driver.name %> &nbsp;|&nbsp; <%= driver.privatePhone %> &nbsp;|&nbsp; 🪪 <%= driver.license %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <div class="alert alert-light border mb-0">
                <span class="fw-semibold">🍔 Food:</span>
                <span id="modal-menu-display"></span>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-dark">Place Order →</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const orderModal = document.getElementById('orderModal');
      orderModal.addEventListener('show.bs.modal', function (event) {
        const btn = event.relatedTarget;
        const menuId = btn.getAttribute('data-menu-id');
        const menuName = btn.getAttribute('data-menu-name');
        const menuPrice = btn.getAttribute('data-menu-price');

        document.getElementById('modal-menu-id').value = menuId;
        document.getElementById('modal-menu-name').textContent = menuName;
        document.getElementById('modal-menu-display').textContent = menuName + '  —  ' + menuPrice;

        const form = document.getElementById('quick-order-form');
        form.querySelector('[name="name"]').value = '';
        form.querySelector('[name="address"]').value = '';
        form.querySelector('[name="DriverId"]').value = '';
      });
    </script>
</body>

</html>

